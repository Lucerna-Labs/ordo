{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ordo",
  "mainBinaryName": "Ordo",
  "version": "0.1.0",
  "identifier": "com.lucernalabs.ordo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ordo",
        "width": 1560,
        "height": 980,
        "minWidth": 1220,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Desktop shell for the Ordo local-first runtime.",
    "longDescription": "Ordo is the desktop operator shell for the Ordo local-first runtime.",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
